# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/cullective
# Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/cullective
MONGODB_URI=mongodb://localhost:27017/cullective

# ─── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Cloudinary (REQUIRED — free tier works) ───────────────────────────────────
# Sign up at cloudinary.com → Dashboard → copy these 3 values
# Free tier: 25GB storage, 25GB bandwidth/month
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
#
# OPTIONAL free Cloudinary add-ons (enable in Cloudinary Console → Add-ons):
#   "Image Quality Analysis" → free tier → enables quality_analysis scoring
#   Basic face detection is always free (no add-on needed)
#   Advanced Face Detection (adv_face) → paid, NOT used in this app

# ─── Google OAuth (OPTIONAL — only needed for "Sign in with Google" button) ────
# Create at console.cloud.google.com → APIs → OAuth 2.0 Client IDs
# Authorized origins: http://localhost:5173
# Authorized redirect URIs: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ─── Frontend URL ───────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── What you DON'T need ────────────────────────────────────────────────────────
# No OpenAI key needed
# No HuggingFace key needed
# No paid Cloudinary add-ons needed
# Everything runs on the free tier
